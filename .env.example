# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
LMC5_ACCESS_TOKEN=replace-with-a-long-random-password
LMC5_PUBLIC_BASE_URL=https://your-domain.example

# Claude Web remote MCP authentication
LMC5_MCP_AUTH_MODE=oauth

# Runtime
LMC5_DATA_DIR=/data
TZ=Asia/Shanghai
PORT=8080
LMC5_MAX_IMPORT_MB=64
LMC5_RECALL_LIMIT=8
LMC5_PULSE_SIZE=2

# Cross-source links: high confidence is active; lower confidence waits for review.
LMC5_RELATION_AUTO_THRESHOLD=0.45
LMC5_RELATION_REVIEW_THRESHOLD=0.25

# Nap and portable vector recall. local_hash stays private and is the safe default.
LMC5_EMBED_PROVIDER=local_hash
LMC5_EMBED_DIM=384
# LMC5_EMBED_MODEL=char-ngram-v1
LMC5_NAP_INTERVAL_MINUTES=60
LMC5_NAP_BATCH_SIZE=40
LMC5_NAP_RELATION_THRESHOLD=0.24

# Optional Xinchao dynamic-mind bridge.
# LMC5_XINCHAO_TOKEN must equal Xinchao's SERVICE_TOKEN.
# LMC5_XINCHAO_BRIDGE_TOKEN is a separate shared secret used only for
# Xinchao -> LMC recall and pending-candidate writes.
LMC5_XINCHAO_URL=
LMC5_XINCHAO_TOKEN=
LMC5_XINCHAO_BRIDGE_TOKEN=

# Night dream: dry_run only creates reviewable candidates; it never promotes them.
LMC5_DREAM_MODE=dry_run
LMC5_DREAM_PROVIDER=local_evidence
LMC5_DREAM_HOUR=4
LMC5_DREAM_MIN_IMPORTANCE=7

# Optional Gemini upgrade. Selected private memory text is sent to Google when enabled.
# LMC5_GEMINI_API_KEY=
# LMC5_EMBED_PROVIDER=gemini
# LMC5_EMBED_MODEL=gemini-embedding-001
# LMC5_DREAM_PROVIDER=gemini
# LMC5_DREAM_MODEL=gemini-2.5-flash
